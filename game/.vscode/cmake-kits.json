[
  {
    "name": "GCC Bartman m68k Win32 (MM2)",
    "toolchainFile": "${workspaceFolder}/cmake/mm2-m68k-bartman.cmake",
    "environmentVariables": {
      "PATH": "${command:amiga.bin-path}/opt/bin;${command:amiga.bin-path};${command:amiga.bin-path}/opt/m68k-amiga-elf/bin;${env:PATH}"
    },
    "preferredGenerator": { "name": "Ninja" },
    "cmakeSettings": {
      "AMIGA": "ON",
      "M68K_CPU": "68020",
      "ACE_USE_AGA_FEATURES": "ON",
      "ACE_USE_ECS_FEATURES": "ON"
    },
    "keep": true
  }
]
