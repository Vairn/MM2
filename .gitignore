# Keep repository focused on source/docs, not game binaries/assets.
*

# Repo metadata
!.gitignore

# Project notes
!CLAUDE.md
!.github/
!.github/**

# Source code
!editor/
!editor/**
!tools/
!tools/**
!wiki/
!wiki/**
!game/
!game/**

# Reverse-engineering docs/source artifacts
!EXTRACTED/
!EXTRACTED/*.asm
!EXTRACTED/*.md
!EXTRACTED/decomp/
!EXTRACTED/decomp/**
!EXTRACTED/docs/
!EXTRACTED/docs/**

# Ignore generated/build/output files even under included paths
editor/build/
editor/build/**
game/build/
game/build/**
wiki/node_modules/
wiki/node_modules/**
wiki/.vitepress/dist/
wiki/.vitepress/dist/**
wiki/.vitepress/cache/
wiki/.vitepress/cache/**
wiki/docs/
wiki/docs/**
wiki/gh-wiki/
wiki/gh-wiki/**
wiki/public/
wiki/public/**
wiki/maze-walker/sprites/
wiki/maze-walker/maps.json
wiki/maze-walker/sprites.json
wiki/mm1-maze-walker/sprites/
wiki/mm1-maze-walker/maps.json
wiki/mm1-maze-walker/sprites.json
build/
build/**
**/__pycache__/
**/*.pyc
**/*.exe
**/*.ppm
imgui.ini

# Ignore bulky extracted image outputs
EXTRACTED/docs/img/
EXTRACTED/docs/img/**
EXTRACTED/event_quiz_answers.json
