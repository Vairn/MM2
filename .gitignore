# Keep repository focused on source/docs, not game binaries/assets.
*

# Repo metadata
!.gitignore

# Project notes
!CLAUDE.md

# Source code
!editor/
!editor/**
!tools/
!tools/**
!wiki/
!wiki/**

# Reverse-engineering docs/source artifacts
!EXTRACTED/
!EXTRACTED/*.asm
!EXTRACTED/*.md
!EXTRACTED/decomp/
!EXTRACTED/decomp/**
!EXTRACTED/docs/
!EXTRACTED/docs/**

# Ignore generated/build/output files even under included paths
editor/build/
editor/build/**
wiki/node_modules/
wiki/node_modules/**
wiki/.vitepress/dist/
wiki/.vitepress/dist/**
wiki/.vitepress/cache/
wiki/.vitepress/cache/**
wiki/docs/
wiki/docs/**
wiki/public/fonts/
wiki/public/fonts/**
build/
build/**
**/__pycache__/
**/*.pyc
**/*.exe
**/*.ppm
imgui.ini

# Ignore bulky extracted image outputs
EXTRACTED/docs/img/
EXTRACTED/docs/img/**
